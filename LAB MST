//MINIMUM LIMIT OF BALLS IN A BAG
class Solution {
public:

bool check(vector<int>& nums, int mid , int maxOperations){
int ans= 0;
for(int x : nums){
    ans+= (x+mid-1)/mid-1;
if(ans> maxOperations) return false;
}
return true;
}
