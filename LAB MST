//MINIMUM INITIAL ENERGY F0R  TASKS
class Solution {
public:
    int minimumEffort(vector<vector<int>>& tasks) {
        int ans = 0;
        for(auto& x : tasks){
            x[0] = x[1] - x[0]; 
        }
        sort(tasks.begin(),tasks.end());
        for(auto& x : tasks){
            ans = max(ans + x[1] - x[0],x[1]);
        }
        return ans;
    }
};
